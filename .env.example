# Copy this file to .env and fill in your key.
# .env is git-ignored — never commit your real key.

# OpenAI API key — used by /api/enhance (gpt-image-2) and auto-pick (gpt-5).
GPT_OPENAPI_API_KEY=sk-your-openai-api-key-here

# Optional overrides:
# JWT_SECRET=your-own-long-random-secret
# IMAGE_MODEL=gpt-image-2
# AUTO_MODEL=gpt-5
# AUTO_REASONING=medium
# IMAGE_QUALITY=high
# IMAGE_SIZE=auto
# INPUT_FIDELITY=high   # only used when IMAGE_MODEL is a gpt-image-1 model
